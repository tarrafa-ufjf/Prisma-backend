# Local PostgreSQL database
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password
DB_DATABASE=your_postgres_database

# Moodle/MySQL institutional database
# Configure through the admin API: /admin/moodle-config.

# Local session auth
SECRET_KEY=change_me_to_a_long_random_secret
MOODLE_CONFIG_ENCRYPTION_KEY=change_me_to_a_different_long_random_secret
SECURITY_PASSWORD_SALT=change_me_to_a_long_random_salt
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
REMEMBER_COOKIE_SAMESITE=Lax
AUTH_ADMIN_EMAIL=admin@example.com
AUTH_ADMIN_PASSWORD=change_me_admin_password

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Optional scheduler settings
SCHEDULER_TIMEZONE=America/Sao_Paulo
